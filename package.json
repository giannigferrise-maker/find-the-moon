{
  "name": "find-the-moon",
  "version": "1.0.0",
  "description": "Moon position finder web app",
  "scripts": {
    "test": "jest --verbose",
    "test:ui": "playwright test",
    "test:all": "jest --verbose && playwright test",
    "test:verify": "jest --verbose --config jest.verify.config.js && playwright test --config playwright.verify.config.js"
  },
  "dependencies": {
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
